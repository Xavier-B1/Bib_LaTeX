@TechReport{luo2021,
  author      = {Luo, Tianyi and Zhou, Lihuan and Falzon, James and Cheng, Yan and Christianson, Giulia and Wu, Yili and Habchi, Amir},
  institution = {World Resources Institute},
  title       = {Assessing Physical Climate Risks for the European Bank for Reconstruction and Development’s Power Generation Project Investment Portfolio},
  year        = {2021},
  abstract    = {Demand for investor disclosure of climate risks to
power generation is increasing, but cost effectively
quantifying physical climate risks at the portfolio level
remains challenging.
This paper introduces a cost-effective yet
comprehensive method for assessing physical
climate risks to power generation projects, and pilot
tests it on the European Bank for Reconstruction
and Development’s (EBRD’s) early 2020 power
generation portfolio.
Under a moderate climate change scenario, EBRD
could expect the projects in its portfolio to experience
a 7.0 terawatt-hour (TWh) (or 3.3 percent) loss
in annual generation by 2030, primarily due to
rising water temperatures and intensified water
stress conditions. 
The unavailability of actual historical disruption
records, limitations of current climate-related data,
and high costs and technical capacity required
are the three biggest factors making quantitative
physical climate risk assessments challenging and
not yet widely accessible to organizations of all sizes
in all markets.},
  doi         = {10.46830/wriwp.21.00060},
  file        = {:assessing-physical-risks-european-bank.pdf:PDF},
  groups      = {Meteo},
  journal     = {World Resources Institute},
  keywords    = {climate risk},
  publisher   = {World Resources Institute},
}

@Article{dietz2016,
  author    = {Dietz, Simon and Bowen, Alex and Dixon, Charlie and Gradwell, Philip},
  journal   = {Nature Climate Change},
  title     = {‘Climate value at risk’ of global financial assets},
  year      = {2016},
  issn      = {1758-6798},
  month     = apr,
  number    = {7},
  pages     = {676--679},
  volume    = {6},
  abstract  = {Investors and financial regulators are increasingly aware of climate-change risks. So far, most of the attention has fallen on whether controls on carbon emissions will strand the assets of fossil-fuel companies. However, it is no less important to ask, what might be the impact of climate change itself on asset values? Here we show how a leading integrated assessment model can be used to estimate the impact of twenty-first-century climate change on the present market value of global financial assets. We find that the expected climate value at risk' (climate VaR) of global financial assets today is 1.8% along a business-as-usual emissions path. Taking a representative estimate of global financial assets, this amounts to US$2.5 trillion. However, much of the risk is in the tail. For example, the 99th percentile climate VaR is 16.9%, or US$24.2 trillion. These estimates would constitute a substantial write-down in the fundamental value of financial assets. Cutting emissions to limit warming to no more than 2 °C reduces the climate VaR by an expected 0.6 percentage points, and the 99th percentile reduction is 7.7 percentage points. Including mitigation costs, the present value of global financial assets is an expected 0.2% higher when warming is limited to no more than 2 °C, compared with business as usual. The 99th percentile is 9.1% higher. Limiting warming to no more than 2 °C makes financial sense to risk-neutral investors - and even more so to the risk averse.},
  doi       = {10.1038/nclimate2972},
  file      = {:Climate value at risk of global financial assets.pdf:PDF},
  groups    = {Meteo},
  publisher = {Springer Science and Business Media LLC},
}

