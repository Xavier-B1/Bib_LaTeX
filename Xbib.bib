@Article{shamsig.2018,
  author   = {Shamsi G., N. and Ali Torabi, S. and Shakouri G., H.},
  journal  = {European Journal of Operational Research},
  title    = {An option contract for vaccine procurement using the {SIR} epidemic model},
  year     = {2018},
  issn     = {0377-2217},
  month    = jun,
  number   = {3},
  pages    = {1122--1140},
  volume   = {267},
  abstract = {Timely and adequate supply of vaccines in disastrous situations has a key role in controlling communicable diseases. This paper develops a specific option contract for proactively provisioning required vaccine doses from two suppliers (a main and a backup). The model aims to minimize the procurement and social costs using the SIR epidemic model. A novel hybrid solution procedure is developed using the optimal control theory, Stackelberg game model and nonlinear programming approaches. To evaluate the performance of the developed solution method, a number of numerical examples are presented and their results are discussed.},
