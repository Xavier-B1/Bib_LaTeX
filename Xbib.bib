@Electronic{deb1,
  address      = {Pittsburgh, PA 15213, USA},
  author       = {Laurens G. Debo and Jiong Sun},
  howpublished = {Working Paper},
  organization = {Carnegie Mellon University},
  title        = {Repeatedly selling to the newsvendor in fluctuating markets: The impact of the discount factor on supply chain},
  url          = {https://student-3k.tepper.cmu.edu/GSIADOC/wp/2004-13.pdf},
  year         = {2004},
  abstract     = {We study coordination of a two-firm supply chain through repeated interaction: In each pe-
riod of an infinite horizon, the upstream firm (the manufacturer) determines the wholesale
price and the downstream firm (the retailer) subsequently sets the order quantity before
the market demand is realized. Both firms discount future profits streams. No inventory
is carried over between periods. In a single-period interaction, the wholesale price contract
cannot achieve supply chain efficiency (or coordination) (Lariviere and Porteus, Manufac-
turing \& Service Operations Management 3(4), 2001). With repeated interaction, we show
that supply chain efficiency can be achieved with the wholesale price contract if the supply
chain members have a sufficiently high discount factor. At the minimum possible discount
factor under which coordination is possible, we show that the manufacturer decreases the
wholesale price, in return for a larger order quantity from the retailer. We show that in-
formation about a parameter of the demand distribution, available to both players in the
beginning of each period, may decrease the retailer's expected profit in a coordinated supply
chain, or constrain supply chain coordination.},
  file         = {:repeatedly_selling_newsvendor_Debo_July_2005.pdf:PDF},
  groups       = {Contracts, Newsvendor},
  keywords     = {newsvendor},
  owner        = {XB},
  timestamp    = {2015.02.13},
}

