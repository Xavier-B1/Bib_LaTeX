@Article{dxi1,
  author    = {Xing, Dahai and Liu, Tieming},
  journal   = {European Journal of Operational Research},
  title     = {Sales effort free riding and coordination with price match and channel rebate},
  year      = {2012},
  number    = {2},
  pages     = {264--271},
  volume    = {219},
  abstract  = {This paper studies sales effort coordination for a supply chain with one manufacturer and two retail channels, where an online retailer offers a lower price and free-rides a brick-and-mortar retailer's sales effort. The free riding effect reduces brick-and-mortar retailer's desired effort level, and thus hurts the manufacturer's profit and the overall supply chain performance. To achieve sales effort coordination, we designed a contract with price match and selective compensation rebate. We also examined other contracts, including the target rebate contract and the wholesale price discount contract, both with price match. The numerical analysis shows that the selective rebate outperforms other contracts in coordinating the brick-and-mortar retailer's sales effort and improving supply chain efficiency.},
  doi       = {10.1016/j.ejor.2011.11.029},
  file      = {:Sales effort free riding and coordination with price match and channel rebate.pdf:PDF},
  isbn      = {0377-2217},
  keywords  = {Price match, Sales effort free riding, Selective rebate, Supply chain management, effort, model},
  owner     = {XB},
  publisher = {{E}lsevier {B}.{V}.},
  timestamp = {2016.10.04},
  url       = {http://dx.doi.org/10.1016/j.ejor.2011.11.029},
}

