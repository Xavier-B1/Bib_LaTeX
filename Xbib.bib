@Article{mac7,
  author    = {Michael A. MacGinnis},
  title     = {The Relative Importance of Cost and Service in Freight Transportation Choice: Before and After Deregulation},
  journal   = {Transportation Journal},
  year      = {1990},
  volume    = {30},
  number    = {1},
  pages     = {12-20},
  abstract  = {Between 1978 and 1980, the airlines, motor freight, and railroad industries in the US were deregulated. The relative importance of service and cost as determinants in shipper freight transportation choice is investigated in order to ascertain whether shipper priorities in the US changed as a result of deregulation. Twelve empirical studies conducted in the 1970s and 1980s are examined. The 6 variables found to affect freight transportation choice are: 1. freight rates, 2. reliability, 3. transit time, 4. loss, damage, claims processing, and tracing, 5. shipper market considerations, and 6. carrier considerations. All of the preregulation studies indicated that service variables were more important than freight rates on the average. In the postderegulation studies, service remained more important overall. However, 2 studies concluded that rates may be more important in some situations, and one study concluded that the increase in emphasis on rates was greater than the increase in emphasis on customer service.},
  owner     = {XB},
  timestamp = {03.10.2008},
}

