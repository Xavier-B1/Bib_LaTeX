@Article{uys_2002,
  author   = {Frederik Uys},
  title    = {Chaos theory and practice : a new management paradigm},
  journal  = {Politeia},
  year     = {2002},
  date     = {2019-01-10},
  volume   = {21},
  issue    = {2},
  pages    = {31-51},
  abstract = {The understanding of chaos theory requires new perspectives and the development of new language and concepts. Chaos theory is a concept that is utilised to describe, analyse and evaluate the complexity of society. The image of organisations as complex, dynamic and self-organising may improve the abilities of practitioners and academics to manage and administrate in times and circumstances that seem chaotic. Chaos management could create stability from disorder, establish better inputs and greater confidence in self-organisation and lessen the pressure on prediction and control. Chaos theory also uses positive feedback by reinforcing deviation from the equilibrium to establish creativity within organisations. The chaos approach is a means of changing thought, behaviour, management styles and organisational patterns to be able to operate effectively in fast-changing and complex circumstances.},
  groups   = {Chaos Theory},
}

