@Article{Lau1,
  author    = {Lau, Hon Shiang and Su, Chang and Wang, Yao Yu and Hua, Zhong Sheng},
  journal   = {Computers and Operations Research},
  title     = {Volume discounting coordinates a supply chain effectively when demand is sensitive to both price and sales effort},
  year      = {2012},
  number    = {12},
  pages     = {3267--3280},
  volume    = {39},
  abstract  = {In this paper, we use a simple and parsimonious model to investigate the performance of volume discounting schemes (hereafter [VD]) in a supply chain where the market demand is sensitive to both retail price p and sales effort e - hereafter called a (p,e)-channel. The problem is analyzed as a manufacturer-leading Stackelberg game. We first present, for the deterministic-system-parameter situation, contract-designing procedures under two contract formats; namely, a regular version of [VD] (hereafter [RVD]) and a continuous version of [VD] (hereafter [CVD]). Our solutions show that [RVD] cannot perfectly coordinate this (p,e)-sensitive channel; moreover, very often [RVD] leads to a lower channel efficiency than the simple price-only contract. In contrast, we show that [CVD] leads to perfect channel coordination - a significant result since most contract formats have been shown in the literature to be unable to coordinate a (p,e)-channel. Next, we consider the more realistic situations in which the manufacturer is uncertain about one of the system parameters - specifically, either the market size a or the effort cost ??. Our results show that, if Manu is uncertain about a, [RVD] becomes useless but the manufacturer can still use [CVD] to benefit himself. When the manufacturer is uncertain about ??, [CVD] remains useful (as expected); however, surprisingly, [RVD] can outperform [CVD] when both the mean value and the uncertainty of ?? are sufficient high. These results underline the necessity of evaluating a contract format under various forms of system-parameter uncertainties - often at the expense of analytical tractability. ?? 2012 Elsevier Ltd. All rights reserved.},
  doi       = {10.1016/j.cor.2012.04.014},
  file      = {:Volume discounting coordinates a SC effectively when demand is sensitive to price and effort.pdf:PDF},
  isbn      = {0305-0548},
  keywords  = {Contract design, Decision under uncertain system parameters, Pricing, Sales effort, Volume discounting, effort, model},
  owner     = {XB},
  publisher = {{E}lsevier},
  timestamp = {2016.10.04},
  url       = {http://dx.doi.org/10.1016/j.cor.2012.04.014},
}

